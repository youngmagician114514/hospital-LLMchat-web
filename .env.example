MODEL_PROVIDER=vllm_openai
# MODEL_PROVIDER=stub
# MODEL_PROVIDER=openai_compat
# MODEL_PROVIDER=hf_local

# vLLM decoupled model service (recommended)
VLLM_API_BASE=http://127.0.0.1:8001/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=qwen2.5-7b-instruct

# OpenAI-compatible gateway config (when MODEL_PROVIDER=openai_compat)
OPENAI_API_BASE=http://127.0.0.1:8001/v1
OPENAI_API_KEY=local-key
OPENAI_MODEL=qwen2.5-7b-instruct

# Shared generation params for OpenAI-compatible providers
GENERATION_TEMPERATURE=0.2
GENERATION_TOP_P=0.9
GENERATION_MAX_TOKENS=512

# Local HF model config (optional fallback)
LOCAL_MODEL_PATH=/home/lwb/Decoding/mydecoding/mydecoding/base_model/qwen/Qwen2___5-7B-Instruct
LOCAL_MODEL_DTYPE=bfloat16
LOCAL_MODEL_DEVICE_MAP=auto
LOCAL_MODEL_MAX_NEW_TOKENS=512
LOCAL_MODEL_TEMPERATURE=0.2
LOCAL_MODEL_TOP_P=0.9
LOCAL_MODEL_REPETITION_PENALTY=1.05
LOCAL_MODEL_MAX_PARALLEL=1

# Runtime config
REQUEST_TIMEOUT_SECONDS=120
MAX_CONCURRENT_MODEL_CALLS=200
MAX_HISTORY_MESSAGES=20
SESSION_TTL_SECONDS=3600
SESSION_CLEANUP_INTERVAL_SECONDS=300
LOG_LEVEL=INFO
